# Copy to `.env.local` and fill in values (never commit `.env.local`).

# Clerk — Dashboard → Configure → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Same screen: "JWKS URL" (ends in /.well-known/jwks.json)
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# OpenAI — used by api/index.py (set on Vercel too for production)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-nano
